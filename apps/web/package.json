{
  "name": "@tw-portfolio/web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev -p ${WEB_PORT:-3000}",
    "build": "npx next build --webpack && cp -r .next/static .next/standalone/apps/web/.next/static",
    "start": "[ -f ../../.env.local ] && set -a && . ../../.env.local && set +a; NODE_ENV=production PORT=${WEB_PORT:-3333} node .next/standalone/apps/web/server.js",
    "test": "vitest run",
    "test:e2e:bypass:mem": "npm run build -w @tw-portfolio/config && npx playwright test --workers=2 --config=tests/e2e/playwright.config.ts",
    "test:e2e:oauth:mem": "npm run build -w @tw-portfolio/config && [ -f ../../.env.local ] && set -a && . ../../.env.local && set +a; npx playwright test --config=tests/e2e/playwright.oauth.config.ts",
    "test:e2e:ci:bypass:mem": "npx playwright test --config=tests/e2e/playwright.config.ts --reporter=junit",
    "test:e2e:ci:oauth:mem": "npx playwright test --config=tests/e2e/playwright.oauth.config.ts --reporter=junit",
    "test:e2e:show-report": "npx playwright show-report playwright-report",
    "test:html": "vitest run --reporter=verbose --reporter=html",
    "test:json": "vitest run --reporter=verbose --reporter=json",
    "test:junit": "vitest run --reporter=verbose --reporter=junit"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tw-portfolio/shared-types": "0.1.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.468.0",
    "next": "16.1.6",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "tailwind-merge": "^2.5.5"
  },
  "devDependencies": {
    "@playwright/test": "^1.51.1",
    "@tw-portfolio/config": "0.1.0",
    "@types/node": "^22.8.6",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.1",
    "@vitest/ui": "^4.0.18",
    "autoprefixer": "^10.4.20",
    "jsdom": "^29.0.1",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.6.3",
    "vitest": "^4.0.18"
  }
}
