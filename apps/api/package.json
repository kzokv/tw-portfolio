{
  "name": "@tw-portfolio/api",
  "version": "0.1.0",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "build": "npx tsc -p tsconfig.json",
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "test": "vitest run",
    "test:http": "npm run build -w @tw-portfolio/config -w @tw-portfolio/test-framework -w @tw-portfolio/test-api && npx playwright test --config test/http/playwright.config.ts",
    "test:http:headed": "npm run build -w @tw-portfolio/config -w @tw-portfolio/test-framework -w @tw-portfolio/test-api && npx playwright test --config test/http/playwright.config.ts --headed",
    "test:http:validate-aaa": "npm run build -w @tw-portfolio/config -w @tw-portfolio/test-framework -w @tw-portfolio/test-api && node test/http/validate-aaa-pairs.mjs",
    "test:integration": "RUN_POSTGRES_INTEGRATION=0 POSTGRES_TEST_DB_URL= POSTGRES_TEST_REDIS_URL= vitest run test/integration/",
    "test:integration:full": "vitest run --no-file-parallelism test/integration/",
    "test:html": "vitest run --reporter=verbose --reporter=html",
    "test:json": "vitest run --reporter=verbose --reporter=json",
    "test:junit": "vitest run --reporter=verbose --reporter=junit"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.1",
    "@tw-portfolio/config": "0.1.0",
    "@tw-portfolio/domain": "0.1.0",
    "@tw-portfolio/shared-types": "0.1.0",
    "fastify": "^5.1.0",
    "pg": "^8.13.1",
    "redis": "^4.7.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@playwright/test": "^1.51.1",
    "@tw-portfolio/test-api": "0.1.0",
    "@tw-portfolio/test-framework": "0.1.0",
    "@types/pg": "^8.11.10",
    "@vitest/ui": "^4.0.18",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^4.0.18"
  }
}
