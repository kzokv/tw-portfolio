{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "rootDir": "src",
    "outDir": "dist",
    "baseUrl": ".",
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "verbatimModuleSyntax": true,
    "isolatedModules": true,
    "moduleDetection": "force",
    "paths": {
      "@vakwen/config/test": [
        "../config/dist/test.d.ts"
      ],
      "@vakwen/test-framework": [
        "../test-framework/dist/index.d.ts"
      ],
      "@vakwen/test-framework/core": [
        "../test-framework/dist/core/index.d.ts"
      ],
      "@vakwen/test-framework/decorators": [
        "../test-framework/dist/decorators/index.d.ts"
      ],
      "@vakwen/test-framework/mixins": [
        "../test-framework/dist/mixins/index.d.ts"
      ],
      "@vakwen/test-framework/config": [
        "../test-framework/dist/config/index.d.ts"
      ]
    }
  },
  "include": [
    "src/**/*.ts"
  ]
}
