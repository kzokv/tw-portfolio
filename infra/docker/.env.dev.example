##########################
# Public domains (single source of truth for tunnel routing and CORS)
PUBLIC_DOMAIN_WEB=twp-dev-web.kzokvdevs.dpdns.org
PUBLIC_DOMAIN_API=twp-dev-api.kzokvdevs.dpdns.org

##########################
# Postgres
POSTGRES_USER=twp
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=tw_portfolio

##########################
# Redis
REDIS_PASSWORD=CHANGE_ME_STRONG_PASSWORD

##########################
# Cloudflare Tunnel
CLOUDFLARE_TUNNEL_TOKEN=PASTE_YOUR_DEV_TUNNEL_TOKEN_HERE

##########################
# Google OAuth (required when AUTH_MODE=oauth)
GOOGLE_CLIENT_ID=PASTE_YOUR_GOOGLE_CLIENT_ID
GOOGLE_CLIENT_SECRET=PASTE_YOUR_GOOGLE_CLIENT_SECRET
SESSION_SECRET=GENERATE_WITH_openssl_rand_-hex_32
# GOOGLE_REDIRECT_URI and APP_BASE_URL are computed in docker-compose.dev.yml
# from PUBLIC_DOMAIN_WEB / PUBLIC_DOMAIN_API. Do not set them here.
#
# SESSION_COOKIE_NAME and COOKIE_DOMAIN work as a pair:
#   - Docker deploys API and web on separate subdomains. The __Host- cookie prefix is
#     host-bound (RFC 6265bis) and cannot be shared across subdomains, so it must not
#     be used here. "g_auth_session" (no prefix) + COOKIE_DOMAIN scopes the session
#     cookie to the shared parent domain, making it visible to both the API (which sets
#     it after OAuth) and the Next.js web proxy (which checks it on every request).
#   - Changing SESSION_COOKIE_NAME invalidates all active sessions.
#   - COOKIE_DOMAIN must be a parent of both PUBLIC_DOMAIN_WEB and PUBLIC_DOMAIN_API.
SESSION_COOKIE_NAME=g_auth_session
COOKIE_DOMAIN=.kzokvdevs.dpdns.org

##########################
# Application (passed to twp-dev-api via env_file)
NODE_ENV=production
AUTH_MODE=oauth
# Required when AUTH_MODE=oauth: stable user id sent by the web app on every API request.
# Set to a single-user id (e.g. your email or "user-1") for this deployment. Do not leave this blank when AUTH_MODE=oauth or the API will return 401 for user-scoped endpoints. Used as build arg for twp-dev-web.
AUTH_USER_ID=user-1
PERSISTENCE_BACKEND=postgres
API_PORT=4000
WEB_PORT=3000
DATA_PROVIDER_TIMEOUT_MS=3000
PRIMARY_PROVIDER=mock-primary
FALLBACK_PROVIDER=mock-fallback
# ALLOWED_ORIGINS is set in docker-compose.dev.yml via Compose interpolation
# (env_file does not support variable expansion)
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_MUTATIONS=120

##########################
# Optional state paths (defaults to $HOME/.local/state/tw-portfolio/dev)
# TWP_STATE_DIR=/home/ubuntu/.local/state/tw-portfolio/dev
# BACKUP_DIR=/home/ubuntu/.local/state/tw-portfolio/dev/backups
# DEPLOY_LOG_DIR=/home/ubuntu/.local/state/tw-portfolio/dev/logs/deploy
