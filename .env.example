##########################
# Environment & modes
NODE_ENV=development
AUTH_MODE=dev_bypass
PERSISTENCE_BACKEND=memory

##########################
# Application ports
WEB_PORT=3000
API_PORT=4000
DB_PORT=5432
REDIS_PORT=6379

##########################
# Postgres mode URLs (optional; required when PERSISTENCE_BACKEND=postgres)
# Local docker-compose defaults:
#DB_URL=postgres://app:app@127.0.0.1:5432/tw_portfolio
#REDIS_URL=redis://127.0.0.1:6379
# External service example (host server IP; do not expose real host IPs in docs/repo):
#DB_URL=postgres://user:password@<HOST_SERVER_IP>:5454/tw_portfolio
#REDIS_URL=redis://:password@<HOST_SERVER_IP>:6363

##########################
# Market data providers
DATA_PROVIDER_TIMEOUT_MS=3000
PRIMARY_PROVIDER=mock-primary
FALLBACK_PROVIDER=mock-fallback

##########################
# Security/Tuning
ALLOWED_ORIGINS=http://127.0.0.1:3000,http://localhost:3000
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_MUTATIONS=120
