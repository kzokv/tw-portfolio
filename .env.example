##########################
## Environment & modes
# [Docker local] 'test' is recommended for local Docker — see runbook for NODE_ENV behavior matrix.
NODE_ENV=development
AUTH_MODE=dev_bypass
PERSISTENCE_BACKEND=memory

##########################
## Application ports
API_PORT=4000
WEB_PORT=3000
DB_PORT=5432
REDIS_PORT=6379

##########################
## Database / Redis URLs                    [postgres only]
# When customizing DB_URL or REDIS_URL via `npm run env:setup`, the script
# prompts for individual components (host, port, user, password, db) and
# composes the URL automatically.
#DB_URL=postgres://twp:PASSWORD@localhost:5432/tw_portfolio
#REDIS_URL=redis://:PASSWORD@localhost:6379

##########################
## Market data providers
DATA_PROVIDER_TIMEOUT_MS=3000
PRIMARY_PROVIDER=mock-primary
FALLBACK_PROVIDER=mock-fallback

##########################
## Security / Tuning
ALLOWED_ORIGINS=http://127.0.0.1:3000,http://localhost:3000
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_MUTATIONS=120
REPAIR_COOLDOWN_MINUTES=60
# Daily purge retention (days) for terminal anonymous_share_tokens. Must be ≥ 30
# to preserve the 30-day UI visibility window. Cron runs 04:00 UTC daily.
ANONYMOUS_SHARE_TOKEN_PURGE_DAYS=90

##########################
## Google OAuth                             [oauth only]
# Switch AUTH_MODE above to "oauth" then uncomment and fill:
#GOOGLE_CLIENT_ID=
#GOOGLE_CLIENT_SECRET=
#GOOGLE_REDIRECT_URI=http://localhost:4000/auth/google/callback
#SESSION_SECRET=<generate with: openssl rand -hex 32>
#APP_BASE_URL=http://localhost:3000
#GOOGLE_TOKEN_URL=
#INITIAL_ADMIN_EMAIL=
# SESSION_COOKIE_NAME and COOKIE_DOMAIN work as a pair:
#   - Default (__Host-g_auth_session) is host-bound and works for same-host local dev.
#   - Docker deploys API and web on separate subdomains — use "g_auth_session" (no __Host-
#     prefix) + COOKIE_DOMAIN to scope the session cookie to the shared parent domain.
#   - Changing SESSION_COOKIE_NAME invalidates all active sessions.
#   - COOKIE_DOMAIN must be a parent of both PUBLIC_DOMAIN_WEB and PUBLIC_DOMAIN_API.
# [Docker local] Do not use __Host- prefix over HTTP — browsers reject it without the Secure flag.
#SESSION_COOKIE_NAME=__Host-g_auth_session
#COOKIE_DOMAIN=

##########################
## FinMind market data provider             [optional]
# KZO-163: provider abstraction + per-provider rate limiting.
# FINMIND_API_TOKEN: leave unset in dev/test — registry falls back to deterministic mock.
# FINMIND_BASE_URL: override only if FinMind moves the dataset endpoint.
# FINMIND_RATE_LIMIT_PER_HOUR: shared budget for backfill + catalog sync + price-fallback route.
#FINMIND_API_TOKEN=
#FINMIND_BASE_URL=https://api.finmindtrade.com/api/v4/data
#FINMIND_RATE_LIMIT_PER_HOUR=600

##########################
## FX rates (KZO-164)                       [optional]
# Frankfurter v2 default-blend FX provider — covers TWD/USD/AUD natively. No quota.
# FRANKFURTER_BASE_URL: override only if Frankfurter moves the API endpoint.
# FX_PROVIDER_MOCK: set to "true" to use the deterministic mock provider in dev/test
#   (registry branches on this; tests set it via vitest config). Defaults to false.
#FRANKFURTER_BASE_URL=https://api.frankfurter.dev/v2
#FX_PROVIDER_MOCK=false

##########################
## AU market data provider (KZO-172)        [optional]
# Yahoo Finance via yahoo-finance2 — bounded AU catalog (BHP/CSL/VAS/WBC/AFI/GMG/IMD).
# Yahoo's ToS limits use to personal/non-commercial; multi-tenant deployments must
# switch to EODHD per spike §7.3.
# YAHOO_AU_RATE_LIMIT_PER_MINUTE: precautionary self-imposed ceiling (Yahoo publishes
#   no public limit). Default 60 req/min from KZO-171 spike §5.
# AU_PROVIDER_MOCK: set to "true" to use the deterministic mock for tests/dev.
# MARKET_DATA_SEARCH_RATE_LIMIT_PER_MINUTE: per-IP cap on `GET /market-data/search`.
#YAHOO_AU_RATE_LIMIT_PER_MINUTE=60
#AU_PROVIDER_MOCK=false
#MARKET_DATA_SEARCH_RATE_LIMIT_PER_MINUTE=20

##########################
## Demo mode                               [optional]
# Set DEMO_MODE_ENABLED=true to show "Try demo" button on the login page.
# Demo sessions create temporary users with seeded portfolio data.
# Expired demo users are cleaned up automatically (postgres only).
#DEMO_MODE_ENABLED=false
#DEMO_SESSION_TTL_SECONDS=1800

##########################
## Web app (Next.js)
NEXT_PUBLIC_AUTH_MODE=dev_bypass
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000
# [Docker local] Compose-internal URL for server-side route handlers inside the container network.
# Set in docker-compose.local.yml — do not add to .env.local.
#SERVER_API_BASE_URL=http://twp-local-api:4000

##########################
## Docker: public domains                   [Docker cloud only]
#PUBLIC_DOMAIN_WEB=twp-dev-web.kzokvdevs.dpdns.org
#PUBLIC_DOMAIN_API=twp-dev-api.kzokvdevs.dpdns.org

##########################
## Docker: infrastructure credentials       [Docker only]
#POSTGRES_USER=twp
#POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
#POSTGRES_DB=tw_portfolio
#REDIS_PASSWORD=CHANGE_ME_STRONG_PASSWORD

##########################
## Docker: Cloudflare tunnel                [Docker cloud only]
#CLOUDFLARE_TUNNEL_TOKEN=PASTE_YOUR_TUNNEL_TOKEN_HERE

##########################
## Docker: application overrides            [Docker only]
#DEPLOY_ENV=dev
#IMAGE_TAG=latest

##########################
## Docker: state paths                      [Docker cloud only]
#TWP_STATE_DIR=/home/ubuntu/.local/state/tw-portfolio/dev
#BACKUP_DIR=/home/ubuntu/.local/state/tw-portfolio/dev/backups
#DEPLOY_LOG_DIR=/home/ubuntu/.local/state/tw-portfolio/dev/logs/deploy

##########################
## Host credentials                         [Lume VM only]
# Mac host username and password — used for SSH tunnel from Lume VM to Mac host
# when running Docker full stack and accessing web containers via localhost.
# See: docs/004-notes/kzo-87/guide-202604011500-local-pg-debug-setup.md
#MAC_USER=
#MAC_PASSWORD=

##########################
## Docker: compose-computed                 [Docker cloud only — computed by docker-compose, do not set manually]
# GOOGLE_REDIRECT_URI=https://${PUBLIC_DOMAIN_API}/auth/google/callback
# APP_BASE_URL=https://${PUBLIC_DOMAIN_WEB}
# DB_URL=postgres://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}
# REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379
# ALLOWED_ORIGINS=https://${PUBLIC_DOMAIN_WEB}
